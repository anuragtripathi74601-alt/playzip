# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/playzip

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# Password
BCRYPT_SALT_ROUNDS=12
PASSWORD_PEPPER=your-secret-pepper-string

# Payment Gateways
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_API_KEY=your_phonepe_api_key
PAYTM_MERCHANT_ID=your_paytm_merchant_id
PAYTM_API_KEY=your_paytm_api_key

# AdMob
ADMOB_APP_ID=ca-app-pub-xxxxxxxxxxxxxxxx~xxxxxxxxxx

# UPI
OWNER_UPI_ID=owner@upi
OWNER_BANK_ACCOUNT=XXXXXXXXXX
OWNER_BANK_IFSC=SBIN0001234

# TDS
TDS_PERCENTAGE=30
TDS_THRESHOLD=10000

# GST
GST_PERCENTAGE=28

# State Restrictions (comma separated)
BANNED_STATES=assam,odisha,telangana,andhra-pradesh
LICENSE_REQUIRED_STATES=nagaland
RESTRICTED_STATES=karnataka

# Admin
MASTER_ADMIN_EMAIL=owner@playzip.com
MASTER_ADMIN_PHONE=+919999999999
